# ─── Supabase ───────────────────────────────────────────────────────────────
# Your Supabase project URL (e.g. https://abcxyz.supabase.co)
SUPABASE_URL=https://[project].supabase.co

# Service-role key — NEVER expose on the client
SUPABASE_SERVICE_KEY=

# Anon/public key (safe for read-only client usage)
SUPABASE_ANON_KEY=

# ─── TheSportsDB ─────────────────────────────────────────────────────────────
# Patreon V2 key — leave empty to fall back to free V1 (key "3")
SPORTSDB_V2_KEY=

# API version: "v2" (Patreon) or "v1" (free). Auto-detected from key presence.
SPORTSDB_API_VERSION=v1

# ─── API-Sports (api-sports.io) ──────────────────────────────────────────────
# Per-sport stats provider (paid, licensed). Per-league routing lives in
# data/system/data_provider_config.json — flip a sport from "espn" to
# "apisports" there to migrate it. Free tier is 100 req/day; paid tiers
# range 7,500 – 75,000 req/day.
API_SPORTS_KEY=

# Optional global override for the stats adapter when no league is passed.
# Per-league config in data_provider_config.json takes precedence.
# Values: espn | thesportsdb | apisports
STATS_PROVIDER=espn

# ─── LLM — Scout's Takes + Ask Scout ─────────────────────────────────────────
# Anthropic only (cheapest tier — claude-haiku-4-5). No fallback provider.
# Per-handle caps live in routes/scoutAsk.ts: 5 calls/min + 50 calls/day.
ANTHROPIC_API_KEY=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
