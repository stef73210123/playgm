# thesportsdb API key — free key is "3", paid keys unlock more endpoints
SPORTSDB_API_KEY=3

# Cron schedule for morning refresh (default: 7:00 AM daily)
REFRESH_CRON=0 7 * * *

# Path to SQLite database file
DB_PATH=./playgm.db

# Directory for daily diff report files (YYYY-MM-DD.json)
REPORTS_DIR=./reports
