# ─── Supabase ───────────────────────────────────────────────────────────────
# Your Supabase project URL (e.g. https://abcxyz.supabase.co)
SUPABASE_URL=https://[project].supabase.co

# Service-role key — NEVER expose on the client
SUPABASE_SERVICE_KEY=

# Anon/public key (safe for read-only client usage)
SUPABASE_ANON_KEY=

# ─── TheSportsDB ─────────────────────────────────────────────────────────────
# Patreon V2 key — leave empty to fall back to free V1 (key "3")
SPORTSDB_V2_KEY=

# API version: "v2" (Patreon) or "v1" (free). Auto-detected from key presence.
SPORTSDB_API_VERSION=v1

# ─── LLM — Scout's Takes + Ask Scout ─────────────────────────────────────────
# Anthropic only (cheapest tier — claude-haiku-4-5). No fallback provider.
# Per-handle caps live in routes/scoutAsk.ts: 5 calls/min + 50 calls/day.
ANTHROPIC_API_KEY=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
