{
  "name": "playgm-server",
  "version": "2026.1.0",
  "description": "PlayGM backend — Fastify + Supabase + TheSportsDB",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/env-loader.ts src/index.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "populate": "tsx --import ./src/env-loader.ts src/scripts/populate.ts",
    "probe-sportsdb": "tsx --import ./src/env-loader.ts src/scripts/probe-sportsdb.ts",
    "reparse-bios": "tsx --import ./src/env-loader.ts src/scripts/reparse-bios.ts",
    "generate-scout-takes": "tsx --import ./src/env-loader.ts src/scripts/generate-scout-takes.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@fastify/cors": "^11.2.0",
    "@supabase/supabase-js": "^2.47.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.1",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
